---
import type { CmsPost } from '../lib/posts';
interface Props { post?: CmsPost | null; }
const { post = null } = Astro.props;
const categorias = ['Digitalização', 'Escala', 'Marketing', 'Gestão', 'Vendas', 'Atendimento', 'Precificação', 'Produtização', 'Disrupção', 'Performance', 'Case de Sucesso', 'Geral'];
const tools = [
  { cmd: 'formatBlock', val: 'h2', label: 'Título H2', txt: 'H2' },
  { cmd: 'formatBlock', val: 'h3', label: 'Título H3', txt: 'H3' },
  { cmd: 'formatBlock', val: 'p', label: 'Parágrafo', txt: 'P' },
  { sep: true },
  { cmd: 'bold', icon: 'bold' },
  { cmd: 'italic', icon: 'italic' },
  { cmd: 'underline', icon: 'underline' },
  { sep: true },
  { cmd: 'insertUnorderedList', icon: 'list' },
  { cmd: 'insertOrderedList', icon: 'list-ordered' },
  { cmd: 'formatBlock', val: 'blockquote', icon: 'quote' },
  { sep: true },
  { cmd: 'createLink', icon: 'link' },
  { cmd: 'insertImage', icon: 'image' },
  { sep: true },
  { cmd: 'removeFormat', icon: 'eraser' },
];
---

<div class="grid lg:grid-cols-[1fr_340px] gap-6 items-start max-w-[1400px]">
  <div class="space-y-6">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
      <label class="block text-sm font-semibold text-gray-700 mb-2">Título do artigo *</label>
      <input id="titulo" type="text" value={post?.title ?? ''} placeholder="Digite o título do artigo" class="w-full px-4 py-3 text-lg font-medium rounded-xl border border-gray-300 focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition" />
      <label class="block text-sm font-semibold text-gray-700 mt-5 mb-2">Slug (URL)</label>
      <input id="slug" type="text" value={post?.slug ?? ''} placeholder="gerado-a-partir-do-titulo" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm text-gray-700 focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition" />
      <p class="text-xs text-gray-400 mt-2">/<span class="text-gray-500">blog/</span><span id="slug-preview" class="text-evolutto-blue">{post?.slug ?? 'novo-artigo'}</span></p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
      <label class="block text-sm font-semibold text-gray-700 px-6 pt-6">Conteúdo *</label>
      <div class="flex flex-wrap items-center gap-1 px-6 py-3 border-b border-gray-100 mt-3 bg-gray-50/60">
        {tools.map((t) => (
          t.sep ? <span class="w-px h-5 bg-gray-200 mx-1"></span> : (
            <button type="button" class="rt-btn h-9 min-w-9 px-2 grid place-items-center rounded-lg text-gray-600 hover:bg-white hover:text-evolutto-blue hover:shadow-sm transition-all text-sm font-bold" data-cmd={t.cmd} data-val={t.val ?? ''} title={t.label ?? t.cmd}>
              {t.txt ? <span>{t.txt}</span> : <i class="w-[18px] h-[18px]" data-lucide={t.icon}></i>}
            </button>
          )
        ))}
      </div>
      <div id="editor" class="rt-editor px-6 py-5 text-[15px]" contenteditable="true" data-placeholder="Escreva o conteúdo do artigo…" set:html={post?.body ?? ''}></div>
    </div>
  </div>

  <aside class="space-y-6">
    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
      <h3 class="text-base font-bold text-gray-900 mb-5">Configurações</h3>
      <label class="block text-sm font-semibold text-gray-700 mb-2">Categoria *</label>
      <select id="categoria" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition">
        {categorias.map((c) => <option value={c} selected={post?.category === c}>{c}</option>)}
      </select>
      <label class="block text-sm font-semibold text-gray-700 mt-5 mb-2">Autor</label>
      <input id="autor" type="text" value={post?.author ?? 'Equipe Evolutto'} class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition" />
      <label class="block text-sm font-semibold text-gray-700 mt-5 mb-2">Foto do autor</label>
      <div class="flex items-center gap-3">
        <span id="autorfoto-preview" class="w-12 h-12 rounded-full bg-evolutto-gradient bg-cover bg-center shrink-0"></span>
        <label class="flex-1 border-2 border-dashed border-gray-300 rounded-xl px-4 py-3 text-center text-xs text-gray-500 cursor-pointer hover:border-evolutto-blue/50 transition-colors"><span id="autorfoto-label">Clique para enviar (máx 2MB)</span><input id="autorfoto-input" type="file" accept="image/*" class="hidden" /></label>
      </div>
      <label class="block text-sm font-semibold text-gray-700 mt-5 mb-2">Tempo de leitura</label>
      <div class="flex items-center gap-2 bg-gray-50 border border-gray-200 rounded-xl px-4 py-3 text-sm text-gray-700">
        <i class="w-4 h-4 text-evolutto-blue" data-lucide="clock"></i>
        <span id="read-time">0 min</span><span id="word-count" class="text-gray-400">(0 palavras)</span>
      </div>
      <label class="block text-sm font-semibold text-gray-700 mt-5 mb-2">Meta descrição</label>
      <textarea id="meta" rows="3" maxlength="160" placeholder="Resposta direta em 150–160 caracteres" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition">{post?.description ?? ''}</textarea>
      <p class="text-xs text-gray-400 mt-1.5"><span id="meta-count">0</span>/160 caracteres</p>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
      <h3 class="text-base font-bold text-gray-900 mb-4">Imagem destaque (capa)</h3>
      <label id="cover-drop" class="relative block aspect-[16/9] rounded-xl border-2 border-dashed border-gray-300 overflow-hidden grid place-items-center cursor-pointer hover:border-evolutto-blue/50 transition-colors text-center">
        <img id="cover-preview" class="absolute inset-0 w-full h-full object-cover hidden" alt="" />
        <div id="cover-ph" class="text-gray-400"><i class="w-7 h-7 mx-auto mb-2" data-lucide="image"></i><p class="text-xs">Clique para enviar a capa</p></div>
        <div id="cover-loading" class="absolute inset-0 bg-white/80 grid place-items-center text-xs font-semibold text-evolutto-blue hidden">Enviando…</div>
        <input id="cover-input" type="file" accept="image/*" class="hidden" />
      </label>
      <button id="cover-remove" type="button" class="mt-2 text-xs text-gray-400 hover:text-red-500 transition-colors hidden">Remover capa</button>
    </div>

    <div class="bg-white rounded-2xl border border-gray-200 shadow-sm p-6">
      <h3 class="text-base font-bold text-gray-900 mb-2 flex items-center gap-2"><i class="w-4 h-4 text-evolutto-blue" data-lucide="zap"></i> Resposta rápida (IA)</h3>
      <p class="text-xs text-gray-400 mb-3">Resumo citável no topo — otimiza para ChatGPT, Perplexity, Gemini.</p>
      <textarea id="tldr" rows="3" placeholder="2–3 linhas que respondem o tema direto" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition">{post?.tldr ?? ''}</textarea>
    </div>
  </aside>
</div>

<script>
  const slugify = (s: string) => s.toLowerCase().normalize('NFD').replace(/[̀-ͯ]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
  const titulo = document.getElementById('titulo') as HTMLInputElement;
  const slug = document.getElementById('slug') as HTMLInputElement;
  const slugPreview = document.getElementById('slug-preview')!;
  const editor = document.getElementById('editor')!;
  const meta = document.getElementById('meta') as HTMLTextAreaElement;
  const metaCount = document.getElementById('meta-count')!;
  const readTime = document.getElementById('read-time')!;
  const wordCount = document.getElementById('word-count')!;

  let slugEdited = !!slug.value;
  slug.addEventListener('input', () => { slugEdited = true; slugPreview.textContent = slug.value || 'novo-artigo'; });
  titulo.addEventListener('input', () => { if (!slugEdited) { slug.value = slugify(titulo.value); slugPreview.textContent = slug.value || 'novo-artigo'; } });

  document.querySelectorAll<HTMLButtonElement>('.rt-btn').forEach((b) => {
    b.addEventListener('click', (e) => {
      e.preventDefault();
      const cmd = b.dataset.cmd!; let val = b.dataset.val || '';
      if (cmd === 'createLink') { val = prompt('URL do link:') || ''; if (!val) return; }
      if (cmd === 'insertImage') { val = prompt('URL da imagem:') || ''; if (!val) return; }
      editor.focus(); document.execCommand(cmd, false, val); updateStats();
    });
  });

  function updateStats() {
    const text = (editor.textContent || '').trim();
    const words = text ? text.split(/\s+/).length : 0;
    const mins = Math.max(1, Math.round(words / 200));
    wordCount.textContent = `(${words} palavras)`;
    readTime.textContent = words ? `${mins} min` : '0 min';
  }
  editor.addEventListener('input', updateStats);
  meta.addEventListener('input', () => { metaCount.textContent = String(meta.value.length); });
  updateStats(); metaCount.textContent = String(meta.value.length);

  // ---- Supabase: carregar (ao editar) e salvar ----
  import { supa, requireAuth } from '../lib/supa';

  const categoria = document.getElementById('categoria') as HTMLSelectElement;
  const autor = document.getElementById('autor') as HTMLInputElement;
  const tldr = document.getElementById('tldr') as HTMLTextAreaElement;
  const btnPub = document.getElementById('btn-publicar') as HTMLButtonElement | null;
  const btnRas = document.getElementById('btn-rascunho') as HTMLButtonElement | null;

  // ---- Upload de imagens (Supabase Storage: bucket evolutto-media) ----
  const coverInput = document.getElementById('cover-input') as HTMLInputElement;
  const coverPreview = document.getElementById('cover-preview') as HTMLImageElement;
  const coverPh = document.getElementById('cover-ph')!;
  const coverLoading = document.getElementById('cover-loading')!;
  const coverRemove = document.getElementById('cover-remove')!;
  const autorFotoInput = document.getElementById('autorfoto-input') as HTMLInputElement;
  const autorFotoPreview = document.getElementById('autorfoto-preview')!;
  const autorFotoLabel = document.getElementById('autorfoto-label')!;

  let coverUrl = '';
  let autorFotoUrl = '';

  async function uploadImg(file: File, folder: string): Promise<string | null> {
    const base = slugify(slug.value || titulo.value || 'img') || 'img';
    const ext = (file.name.split('.').pop() || 'jpg').toLowerCase().replace(/[^a-z0-9]/g, '') || 'jpg';
    const path = `${folder}/${base}-${Date.now()}.${ext}`;
    const { error } = await supa.storage.from('evolutto-media').upload(path, file, { upsert: true, contentType: file.type || 'image/jpeg' });
    if (error) { alert('Erro no upload: ' + error.message); return null; }
    return supa.storage.from('evolutto-media').getPublicUrl(path).data.publicUrl;
  }
  function showCover(u: string) {
    coverUrl = u; coverPreview.src = u; coverPreview.classList.remove('hidden');
    coverPh.classList.add('hidden'); coverRemove.classList.remove('hidden');
  }
  coverInput?.addEventListener('change', async () => {
    const f = coverInput.files?.[0]; if (!f) return;
    if (f.size > 5 * 1024 * 1024) { alert('Imagem muito grande (máx 5MB).'); coverInput.value = ''; return; }
    coverLoading.classList.remove('hidden');
    const u = await uploadImg(f, 'covers');
    coverLoading.classList.add('hidden');
    if (u) showCover(u);
    coverInput.value = '';
  });
  coverRemove?.addEventListener('click', () => {
    coverUrl = ''; coverPreview.src = ''; coverPreview.classList.add('hidden');
    coverPh.classList.remove('hidden'); coverRemove.classList.add('hidden');
  });
  autorFotoInput?.addEventListener('change', async () => {
    const f = autorFotoInput.files?.[0]; if (!f) return;
    if (f.size > 2 * 1024 * 1024) { alert('Foto muito grande (máx 2MB).'); autorFotoInput.value = ''; return; }
    autorFotoLabel.textContent = 'Enviando…';
    const u = await uploadImg(f, 'autores');
    if (u) { autorFotoUrl = u; (autorFotoPreview as HTMLElement).style.backgroundImage = `url(${u})`; autorFotoLabel.textContent = 'Trocar foto'; }
    else { autorFotoLabel.textContent = 'Clique para enviar (máx 2MB)'; }
    autorFotoInput.value = '';
  });

  const editSlug = new URLSearchParams(location.search).get('slug');
  let editId: string | null = null; // id do artigo em edição

  // Se estiver editando, busca o artigo e preenche o formulário
  if (editSlug) {
    const { data, error } = await supa.from('evolutto_articles').select('*').eq('slug', editSlug).maybeSingle();
    if (error) { alert('Erro ao carregar o artigo: ' + error.message); }
    else if (data) {
      editId = data.id;
      titulo.value = data.title || '';
      slug.value = data.slug || ''; slugEdited = true; slugPreview.textContent = data.slug || 'novo-artigo';
      editor.innerHTML = data.body || '';
      if (data.category) categoria.value = data.category;
      autor.value = data.author || 'Equipe Evolutto';
      meta.value = data.seo_description || data.description || '';
      tldr.value = data.tldr || '';
      if (data.cover) showCover(data.cover);
      if (data.author_photo) { autorFotoUrl = data.author_photo; (autorFotoPreview as HTMLElement).style.backgroundImage = `url(${data.author_photo})`; autorFotoLabel.textContent = 'Trocar foto'; }
      updateStats(); metaCount.textContent = String(meta.value.length);
    }
  }

  function countWords() {
    const text = (editor.textContent || '').trim();
    return text ? text.split(/\s+/).filter(Boolean).length : 0;
  }

  async function salvar(status: 'published' | 'draft', btn: HTMLButtonElement | null) {
    const session = await requireAuth();
    if (!session) return; // requireAuth já redireciona pro /acesso
    const t = titulo.value.trim();
    if (!t) { alert('Dê um título ao artigo.'); titulo.focus(); return; }
    const body = (editor as HTMLElement).innerHTML.trim();
    if (!body) { alert('Escreva o conteúdo do artigo.'); editor.focus(); return; }
    const s = (slug.value.trim() || slugify(t));
    const desc = meta.value.trim() || null;
    const hoje = new Date().toISOString().slice(0, 10);
    const row: Record<string, any> = {
      slug: s, title: t, body,
      category: categoria.value,
      author: autor.value.trim() || 'Equipe Evolutto',
      description: desc, seo_description: desc,
      tldr: tldr.value.trim() || null,
      cover: coverUrl || null,
      og_image: coverUrl || null,
      author_photo: autorFotoUrl || null,
      reading_time: Math.max(1, Math.round(countWords() / 200)),
      status, updated_date: hoje,
    };
    const orig = btn ? btn.textContent : '';
    if (btn) { btn.disabled = true; btn.textContent = 'Salvando…'; }
    let error: any = null;
    if (editId) {
      ({ error } = await supa.from('evolutto_articles').update(row).eq('id', editId));
    } else {
      if (status === 'published') row.pub_date = hoje;
      ({ error } = await supa.from('evolutto_articles').insert(row));
    }
    if (error) {
      if (btn) { btn.disabled = false; btn.textContent = orig; }
      alert(error.code === '23505' ? 'Já existe um artigo com esse slug. Mude o slug.' : 'Erro ao salvar: ' + error.message);
      return;
    }
    location.href = '/artigos';
  }

  btnPub?.addEventListener('click', () => salvar('published', btnPub));
  btnRas?.addEventListener('click', () => salvar('draft', btnRas));
</script>
