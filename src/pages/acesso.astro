---
import '../styles/global.css';
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="robots" content="noindex" />
    <title>Entrar — Evolutto CMS</title>
  </head>
  <body class="bg-evolutto-black text-white antialiased min-h-screen grid place-items-center px-6 relative overflow-hidden">
    <div class="absolute top-[-10%] left-1/2 -translate-x-1/2 w-[60%] h-96 bg-evolutto-blue/25 blur-[130px] rounded-full"></div>
    <div class="absolute inset-0 opacity-[0.04]" style="background-image: radial-gradient(#fff 1px, transparent 1px); background-size: 22px 22px;"></div>

    <div class="relative z-10 w-full max-w-sm">
      <div class="flex items-center justify-center gap-2.5 mb-8">
        <img src="/evolutto-logo-white.png" alt="Evolutto" style="height:28px;width:auto" />
        <span class="text-[10px] font-bold uppercase tracking-[0.18em] text-evolutto-blue border border-evolutto-blue/40 rounded px-1.5 py-0.5">CMS</span>
      </div>
      <div class="bg-white rounded-[2rem] p-8 shadow-2xl text-gray-900">
        <h1 class="text-2xl font-bold tracking-tight mb-1">Entrar</h1>
        <p class="text-sm text-gray-500 mb-6">Acesse o painel de conteúdo da Evolutto.</p>
        <form id="login-form" class="space-y-4">
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">E-mail</label>
            <input id="email" type="email" required placeholder="voce@evolutto.com" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition" />
          </div>
          <div>
            <label class="block text-sm font-semibold text-gray-700 mb-1.5">Senha</label>
            <input id="senha" type="password" required placeholder="••••••••" class="w-full px-4 py-3 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue transition" />
          </div>
          <p id="erro" class="hidden text-sm text-evolutto-red"></p>
          <button id="btn" type="submit" class="w-full bg-evolutto-blue text-white text-sm font-bold py-3.5 rounded-full hover:brightness-110 transition-all shadow-lg shadow-evolutto-blue/30">Entrar</button>
        </form>
        <p class="text-xs text-gray-400 text-center mt-5">Acesso restrito à equipe Evolutto.</p>
      </div>
    </div>

    <script>
      import { supa } from '../lib/supa';
      // se já logado, vai direto pro painel
      supa.auth.getSession().then(({ data }) => { if (data.session) window.location.href = '/'; });
      const form = document.getElementById('login-form');
      const erro = document.getElementById('erro');
      const btn = document.getElementById('btn');
      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        erro.classList.add('hidden');
        btn.disabled = true; btn.textContent = 'Entrando…';
        const email = (document.getElementById('email') as HTMLInputElement).value.trim();
        const password = (document.getElementById('senha') as HTMLInputElement).value;
        const { error } = await supa.auth.signInWithPassword({ email, password });
        if (error) {
          erro.textContent = 'E-mail ou senha inválidos.'; erro.classList.remove('hidden');
          btn.disabled = false; btn.textContent = 'Entrar';
        } else {
          window.location.href = '/';
        }
      });
    </script>
  </body>
</html>
