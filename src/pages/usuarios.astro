---
import CmsLayout from '../layouts/CmsLayout.astro';
const papeis = ['Admin Full', 'Editor', 'Autor', 'Revisor'];
---

<CmsLayout title="Usuários" active="usuarios">
  <button slot="actions" id="novo" class="inline-flex items-center gap-2 bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/30"><i class="w-4 h-4" data-lucide="user-plus"></i> Novo usuário</button>

  <div id="form" class="hidden bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-6 max-w-2xl">
    <h2 id="form-titulo" class="text-base font-bold text-gray-900 mb-5">Novo usuário</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Nome</label><input id="u-nome" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="Nome completo" /></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">E-mail</label><input id="u-email" type="email" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="email@evolutto.com" /></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Papel</label><select id="u-papel" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue">{papeis.map((p) => <option>{p}</option>)}</select></div>
      <div><label id="u-senha-label" class="block text-sm font-semibold text-gray-700 mb-1.5">Senha provisória</label><input id="u-senha" type="text" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="mín. 6 caracteres" /></div>
    </div>
    <p class="text-xs text-gray-400 mt-3">Papéis: <b>Admin Full</b> tudo · <b>Editor</b> publica · <b>Autor</b> cria rascunhos · <b>Revisor</b> comenta/aprova.</p>
    <div class="flex gap-2 mt-5"><button id="salvar" class="bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110">Salvar usuário</button><button id="cancelar" class="text-sm font-semibold text-gray-600 px-4 py-2.5 rounded-full border border-gray-300 hover:bg-gray-100">Cancelar</button></div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead><tr class="text-left text-[0.65rem] font-semibold uppercase tracking-widest text-gray-400 border-b border-gray-100"><th class="px-6 py-3">Usuário</th><th class="px-6 py-3">Papel</th><th class="px-6 py-3">Status</th><th class="px-6 py-3 text-right">Ações</th></tr></thead>
      <tbody id="rows"><tr><td colspan="4" class="px-6 py-10 text-center text-gray-400 text-sm">Carregando…</td></tr></tbody>
    </table>
  </div>

  <script>
    import { supa, requireAuth } from '../lib/supa';
    import { createIcons, icons } from 'lucide';

    const esc = (s: string) => (s || '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
    const iniciais = (n: string) => (n || '?').split(' ').map((x) => x[0]).slice(0, 2).join('').toUpperCase();
    const cor: Record<string, string> = { 'Admin Full': 'text-evolutto-blue bg-evolutto-blue/10', 'Editor': 'text-purple-700 bg-purple-100', 'Autor': 'text-amber-700 bg-amber-100', 'Revisor': 'text-gray-600 bg-gray-200' };
    const rows = document.getElementById('rows')!;
    const form = document.getElementById('form')!;
    const formTitulo = document.getElementById('form-titulo')!;
    const fNome = document.getElementById('u-nome') as HTMLInputElement;
    const fEmail = document.getElementById('u-email') as HTMLInputElement;
    const fPapel = document.getElementById('u-papel') as HTMLSelectElement;
    const fSenha = document.getElementById('u-senha') as HTMLInputElement;
    const senhaWrap = fSenha.closest('div')!;
    let editId: string | null = null;

    function abrirNovo() {
      editId = null; formTitulo.textContent = 'Novo usuário';
      fNome.value = ''; fEmail.value = ''; fPapel.selectedIndex = 0; fSenha.value = '';
      fEmail.disabled = false; senhaWrap.style.display = '';
      form.classList.remove('hidden'); form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    function abrirEdicao(u: any) {
      editId = u.id; formTitulo.textContent = 'Editar usuário';
      fNome.value = u.nome || ''; fEmail.value = u.email || ''; fPapel.value = u.papel || 'Autor';
      fEmail.disabled = true; senhaWrap.style.display = 'none'; // e-mail/senha não mudam aqui
      form.classList.remove('hidden'); form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }

    document.getElementById('novo')?.addEventListener('click', abrirNovo);
    document.getElementById('cancelar')?.addEventListener('click', () => form.classList.add('hidden'));
    document.getElementById('salvar')?.addEventListener('click', async () => {
      const nome = fNome.value.trim();
      const btn = document.getElementById('salvar') as HTMLButtonElement;
      if (editId) {
        // editar perfil existente (nome + papel)
        const { error } = await supa.from('evolutto_profiles').update({ nome, papel: fPapel.value }).eq('id', editId);
        if (error) { alert('Erro: ' + error.message); return; }
        form.classList.add('hidden'); carregar(); return;
      }
      // criar novo usuário (via função admin)
      const email = fEmail.value.trim(); const senha = fSenha.value.trim();
      if (!email || senha.length < 6) { alert('Informe e-mail e uma senha de no mínimo 6 caracteres.'); return; }
      btn.disabled = true; btn.textContent = 'Criando…';
      const { data, error } = await supa.functions.invoke('create-user', { body: { nome, email, senha, papel: fPapel.value } });
      btn.disabled = false; btn.textContent = 'Salvar usuário';
      if (error || (data && data.error)) { alert('Erro ao criar: ' + (data?.error || error?.message || 'desconhecido') + '\n(A função create-user está deployada?)'); return; }
      form.classList.add('hidden'); carregar();
    });

    async function toggleAtivo(id: string, ativo: boolean) {
      const { error } = await supa.from('evolutto_profiles').update({ ativo: !ativo }).eq('id', id);
      if (error) alert('Erro: ' + error.message); else carregar();
    }

    async function carregar() {
      const session = await requireAuth(); if (!session) return;
      const { data, error } = await supa.from('evolutto_profiles').select('*').order('created_at', { ascending: true });
      if (error) { rows.innerHTML = `<tr><td colspan="4" class="px-6 py-10 text-center text-red-500 text-sm">Erro: ${esc(error.message)} (rodou a migração 0004?)</td></tr>`; return; }
      const list = data || [];
      if (!list.length) { rows.innerHTML = '<tr><td colspan="4" class="px-6 py-10 text-center text-gray-400 text-sm">Nenhum usuário. Clique em “Novo usuário”.</td></tr>'; return; }
      rows.innerHTML = list.map((u) => `
        <tr class="border-b border-gray-50 hover:bg-gray-50/60 transition-colors">
          <td class="px-6 py-4"><div class="flex items-center gap-3"><span class="w-9 h-9 rounded-full bg-evolutto-gradient grid place-items-center text-white text-xs font-bold shrink-0">${esc(iniciais(u.nome || u.email))}</span><div><p class="font-medium text-gray-900">${esc(u.nome || '—')}</p><p class="text-xs text-gray-400">${esc(u.email || '')}</p></div></div></td>
          <td class="px-6 py-4"><span class="inline-flex text-[0.6rem] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${cor[u.papel] || 'text-gray-600 bg-gray-200'}">${esc(u.papel || 'Autor')}</span></td>
          <td class="px-6 py-4"><button class="t-ativo inline-flex text-[0.6rem] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${u.ativo ? 'text-green-700 bg-green-100' : 'text-gray-500 bg-gray-200'}" data-id="${u.id}" data-ativo="${u.ativo}">${u.ativo ? 'Ativo' : 'Inativo'}</button></td>
          <td class="px-6 py-4"><div class="flex items-center justify-end gap-2"><button class="b-editar w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-blue hover:bg-evolutto-blue/10" data-id="${u.id}"><i class="w-4 h-4" data-lucide="pencil"></i></button></div></td>
        </tr>`).join('');
      createIcons({ icons });
      rows.querySelectorAll<HTMLElement>('.t-ativo').forEach((b) => b.addEventListener('click', () => toggleAtivo(b.dataset.id!, b.dataset.ativo === 'true')));
      rows.querySelectorAll<HTMLElement>('.b-editar').forEach((b) => b.addEventListener('click', () => abrirEdicao(list.find((x) => x.id === b.dataset.id))));
    }
    carregar();
  </script>
</CmsLayout>
