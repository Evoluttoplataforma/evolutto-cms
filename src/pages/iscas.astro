---
import CmsLayout from '../layouts/CmsLayout.astro';
const U = '/wp-content/uploads';
const iscas = [
  { titulo: 'eBook: Passos para a Digitalização', tipo: 'eBook', downloads: 1290, ativo: true, url: `${U}/2024/02/cms_files_198426_1614344601ebook-evolutto-passos-para-a-digitalizacao.pdf` },
  { titulo: 'eBook: Passo a Passo para Escalar a Consultoria', tipo: 'eBook', downloads: 842, ativo: true, url: `${U}/2024/05/EBOOK-EVOLUTTO-PassoaPasso-EscalarConsultoria-1.pdf` },
  { titulo: 'eBook: Atenda 50 Clientes Simultaneamente', tipo: 'eBook', downloads: 651, ativo: true, url: `${U}/2024/05/cms_files_198426_1611841844Ebook_-_Evolutto_-_Aprenda_a_Atender_50_Clientes_Simultaneamente.pdf` },
  { titulo: 'Playbook de Calls 2.0', tipo: 'Playbook', downloads: 318, ativo: true, url: `${U}/2024/04/PLAYBOOK-DE-CALLS-2.0-1.pdf` },
  { titulo: 'Guia: Consultoria Tradicional x Escalável', tipo: 'Guia', downloads: 95, ativo: true, url: `${U}/2025/12/consultoria_tradicional_escalavel_20251201233036.pdf` },
];
const tipos = ['eBook', 'Checklist', 'Planilha', 'Playbook', 'Guia', 'Template', 'Webinar'];
---

<CmsLayout title="Iscas Digitais" active="iscas">
  <button slot="actions" id="novo" class="inline-flex items-center gap-2 bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/30"><i class="w-4 h-4" data-lucide="plus"></i> Nova isca</button>

  <div id="form" class="hidden bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-6 max-w-2xl">
    <h2 class="text-base font-bold text-gray-900 mb-5">Nova isca digital</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Título</label><input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="Ex.: eBook: Passos para a Digitalização" /></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Tipo</label><select class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue">{tipos.map((t) => <option>{t}</option>)}</select></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">CTA (texto do botão)</label><input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="Baixar agora" /></div>
      <div class="sm:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Arquivo / URL do material</label><input class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="https://… (PDF, planilha, etc.)" /></div>
      <div class="sm:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Descrição</label><textarea rows="2" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm resize-none focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="O que a pessoa recebe ao baixar"></textarea></div>
    </div>
    <div class="flex gap-2 mt-5"><button class="bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110" onclick="alert('Salvar: Supabase em breve')">Criar isca</button><button id="cancelar" class="text-sm font-semibold text-gray-600 px-4 py-2.5 rounded-full border border-gray-300 hover:bg-gray-100">Cancelar</button></div>
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <table class="w-full text-sm">
      <thead><tr class="text-left text-[0.65rem] font-semibold uppercase tracking-widest text-gray-400 border-b border-gray-100"><th class="px-6 py-3">Isca</th><th class="px-6 py-3">Tipo</th><th class="px-6 py-3">Downloads</th><th class="px-6 py-3">Status</th><th class="px-6 py-3 text-right">Ações</th></tr></thead>
      <tbody>
        {iscas.map((i) => (
          <tr class="border-b border-gray-50 hover:bg-gray-50/60 transition-colors">
            <td class="px-6 py-4"><a href={i.url} target="_blank" rel="noopener" class="flex items-center gap-3 group"><span class="w-9 h-9 rounded-lg bg-evolutto-blue/10 text-evolutto-blue grid place-items-center"><i class="w-4 h-4" data-lucide="magnet"></i></span><span class="font-medium text-gray-900 group-hover:text-evolutto-blue transition-colors">{i.titulo}</span></a></td>
            <td class="px-6 py-4 text-gray-600">{i.tipo}</td>
            <td class="px-6 py-4 text-gray-600 font-semibold">{i.downloads}</td>
            <td class="px-6 py-4"><span class={`inline-flex text-[0.6rem] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${i.ativo ? 'text-green-700 bg-green-100' : 'text-gray-500 bg-gray-200'}`}>{i.ativo ? 'Ativa' : 'Inativa'}</span></td>
            <td class="px-6 py-4"><div class="flex items-center justify-end gap-2">
              <a href={i.url} target="_blank" rel="noopener" class="w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-blue hover:bg-evolutto-blue/10" title="Baixar / abrir material"><i class="w-4 h-4" data-lucide="download"></i></a>
              <button class="w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-blue hover:bg-evolutto-blue/10"><i class="w-4 h-4" data-lucide="pencil"></i></button>
              <button class="w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-red hover:bg-evolutto-red/10"><i class="w-4 h-4" data-lucide="trash-2"></i></button>
            </div></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <script>
    const f = document.getElementById('form')!;
    document.getElementById('novo')?.addEventListener('click', () => f.classList.toggle('hidden'));
    document.getElementById('cancelar')?.addEventListener('click', () => f.classList.add('hidden'));
  </script>
</CmsLayout>
