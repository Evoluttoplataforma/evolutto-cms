---
import CmsLayout from '../layouts/CmsLayout.astro';
import { getCmsPosts, fmtBR } from '../lib/posts';

const posts = getCmsPosts();
const publicados = posts.filter((p) => !p.draft).length;
const rascunhos = posts.filter((p) => p.draft).length;
const stats = [
  { label: 'Total de artigos', value: String(posts.length), accent: false },
  { label: 'Publicados', value: String(publicados), accent: true },
  { label: 'Rascunhos', value: String(rascunhos), accent: false },
  { label: 'Usuários', value: '4', accent: false },
  { label: 'Histórias pendentes', value: '0', accent: true },
];
const recentes = posts.slice(0, 6);
---

<CmsLayout title="Dashboard" active="dashboard">
  <a slot="actions" href="/artigos/novo" class="inline-flex items-center gap-2 bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/30"><i class="w-4 h-4" data-lucide="square-pen"></i> Novo Artigo</a>

  <div class="grid grid-cols-2 lg:grid-cols-5 gap-4 mb-8">
    {stats.map((s) => (
      <div class="bg-white rounded-2xl border border-gray-200 p-6 shadow-sm">
        <p class="text-sm text-gray-500 mb-3">{s.label}</p>
        <p class={`text-4xl font-bold tracking-tight ${s.accent ? 'text-evolutto-blue' : 'text-gray-900'}`}>{s.value}</p>
      </div>
    ))}
  </div>

  <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
    <div class="flex items-center justify-between px-6 py-5 border-b border-gray-100">
      <h2 class="text-lg font-bold tracking-tight text-gray-900">Artigos recentes</h2>
      <a href="/artigos" class="text-sm font-semibold text-evolutto-blue hover:underline">Ver todos</a>
    </div>
    <table class="w-full text-sm">
      <thead><tr class="text-left text-[0.65rem] font-semibold uppercase tracking-widest text-gray-400 border-b border-gray-100"><th class="px-6 py-3">Título</th><th class="px-6 py-3">Categoria</th><th class="px-6 py-3">Status</th><th class="px-6 py-3">Data</th><th class="px-6 py-3 text-right">Ações</th></tr></thead>
      <tbody>
        {recentes.map((a) => (
          <tr class="border-b border-gray-50 hover:bg-gray-50/60 transition-colors">
            <td class="px-6 py-4"><div class="flex items-center gap-3"><span class="w-9 h-9 rounded-lg bg-evolutto-gradient shrink-0"></span><span class="font-medium text-gray-900 max-w-md truncate">{a.title}</span></div></td>
            <td class="px-6 py-4 text-gray-600">{a.category}</td>
            <td class="px-6 py-4"><span class={`inline-flex text-[0.6rem] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${a.draft ? 'text-amber-700 bg-amber-100' : 'text-green-700 bg-green-100'}`}>{a.draft ? 'Rascunho' : 'Publicado'}</span></td>
            <td class="px-6 py-4 text-gray-500 whitespace-nowrap">{fmtBR(a.pubDate)}</td>
            <td class="px-6 py-4"><div class="flex items-center justify-end gap-2"><a href="https://blog.evolutto.com" class="w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-blue hover:bg-evolutto-blue/10 transition-colors"><i class="w-4 h-4" data-lucide="eye"></i></a><a href={`/artigos/editar/${a.slug}`} class="w-9 h-9 grid place-items-center rounded-lg text-gray-500 hover:text-evolutto-blue hover:bg-evolutto-blue/10 transition-colors"><i class="w-4 h-4" data-lucide="pencil"></i></a></div></td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</CmsLayout>
