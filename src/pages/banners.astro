---
import CmsLayout from '../layouts/CmsLayout.astro';
const posicoes = ['Topo do site', 'Sidebar do blog', 'Rodapé', 'Dentro do artigo'];
---

<CmsLayout title="Banners" active="banners">
  <button slot="actions" id="novo" class="inline-flex items-center gap-2 bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110 hover:scale-105 transition-all shadow-lg shadow-evolutto-blue/30"><i class="w-4 h-4" data-lucide="plus"></i> Novo banner</button>

  <div id="form" class="hidden bg-white rounded-2xl border border-gray-200 shadow-sm p-6 mb-6 max-w-2xl">
    <h2 id="form-titulo" class="text-base font-bold text-gray-900 mb-5">Novo banner</h2>
    <div class="grid sm:grid-cols-2 gap-4">
      <div class="sm:col-span-2"><label class="block text-sm font-semibold text-gray-700 mb-1.5">Título</label><input id="b-titulo" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="Título do banner" /></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Posição</label><select id="b-posicao" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm bg-white focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue">{posicoes.map((p) => <option>{p}</option>)}</select></div>
      <div><label class="block text-sm font-semibold text-gray-700 mb-1.5">Link de destino</label><input id="b-link" class="w-full px-4 py-2.5 rounded-xl border border-gray-300 text-sm focus:outline-none focus:ring-2 focus:ring-evolutto-blue/30 focus:border-evolutto-blue" placeholder="/pagina ou https://" /></div>
      <div class="sm:col-span-2">
        <label class="block text-sm font-semibold text-gray-700 mb-1.5">Imagem</label>
        <label id="b-drop" class="relative block aspect-[16/5] rounded-xl border-2 border-dashed border-gray-300 overflow-hidden grid place-items-center cursor-pointer hover:border-evolutto-blue/50 text-gray-400 text-center">
          <img id="b-preview" class="absolute inset-0 w-full h-full object-cover hidden" alt="" />
          <div id="b-ph"><i class="w-6 h-6 mx-auto mb-1" data-lucide="image"></i><p class="text-xs">Clique para enviar</p></div>
          <div id="b-loading" class="absolute inset-0 bg-white/80 grid place-items-center text-xs font-semibold text-evolutto-blue hidden">Enviando…</div>
          <input id="b-file" type="file" accept="image/*" class="hidden" />
        </label>
      </div>
    </div>
    <div class="flex gap-2 mt-5"><button id="salvar" class="bg-evolutto-blue text-white text-sm font-bold px-5 py-2.5 rounded-full hover:brightness-110">Salvar banner</button><button id="cancelar" class="text-sm font-semibold text-gray-600 px-4 py-2.5 rounded-full border border-gray-300 hover:bg-gray-100">Cancelar</button></div>
  </div>

  <div id="grid" class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    <p id="vazio" class="text-gray-400 text-sm">Carregando…</p>
  </div>

  <script>
    import { supa, requireAuth, uploadMedia } from '../lib/supa';
    import { createIcons, icons } from 'lucide';

    const esc = (s: string) => (s || '').replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c]!));
    const grid = document.getElementById('grid')!;
    const form = document.getElementById('form')!;
    const formTitulo = document.getElementById('form-titulo')!;
    const fTit = document.getElementById('b-titulo') as HTMLInputElement;
    const fPos = document.getElementById('b-posicao') as HTMLSelectElement;
    const fLink = document.getElementById('b-link') as HTMLInputElement;
    const fFile = document.getElementById('b-file') as HTMLInputElement;
    const preview = document.getElementById('b-preview') as HTMLImageElement;
    const ph = document.getElementById('b-ph')!;
    const loading = document.getElementById('b-loading')!;
    let editId: string | null = null;
    let imagemUrl = '';

    function showImg(u: string) { imagemUrl = u; preview.src = u; preview.classList.remove('hidden'); ph.classList.add('hidden'); }
    function clearImg() { imagemUrl = ''; preview.src = ''; preview.classList.add('hidden'); ph.classList.remove('hidden'); }

    function abrirNovo() {
      editId = null; formTitulo.textContent = 'Novo banner';
      fTit.value = ''; fPos.selectedIndex = 0; fLink.value = ''; clearImg();
      form.classList.remove('hidden'); form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    function abrirEdicao(b: any) {
      editId = b.id; formTitulo.textContent = 'Editar banner';
      fTit.value = b.titulo || ''; fPos.value = b.posicao || posicoes_default(); fLink.value = b.link || '';
      if (b.imagem_url) showImg(b.imagem_url); else clearImg();
      form.classList.remove('hidden'); form.scrollIntoView({ behavior: 'smooth', block: 'center' });
    }
    function posicoes_default() { return fPos.options[0].value; }

    fFile?.addEventListener('change', async () => {
      const f = fFile.files?.[0]; if (!f) return;
      if (f.size > 5 * 1024 * 1024) { alert('Imagem muito grande (máx 5MB).'); fFile.value = ''; return; }
      loading.classList.remove('hidden');
      try { showImg(await uploadMedia(f, 'banners')); } catch (e: any) { alert('Erro no upload: ' + e.message); }
      loading.classList.add('hidden'); fFile.value = '';
    });

    document.getElementById('novo')?.addEventListener('click', abrirNovo);
    document.getElementById('cancelar')?.addEventListener('click', () => form.classList.add('hidden'));
    document.getElementById('salvar')?.addEventListener('click', async () => {
      const titulo = fTit.value.trim(); if (!titulo) { alert('Dê um título ao banner.'); return; }
      const row = { titulo, posicao: fPos.value, link: fLink.value.trim() || null, imagem_url: imagemUrl || null };
      const { error } = editId
        ? await supa.from('evolutto_banners').update(row).eq('id', editId)
        : await supa.from('evolutto_banners').insert(row);
      if (error) { alert('Erro ao salvar: ' + error.message); return; }
      form.classList.add('hidden'); carregar();
    });

    async function toggleAtivo(id: string, ativo: boolean) {
      const { error } = await supa.from('evolutto_banners').update({ ativo: !ativo }).eq('id', id);
      if (error) alert('Erro: ' + error.message); else carregar();
    }
    async function excluir(id: string) {
      if (!confirm('Excluir este banner?')) return;
      const { error } = await supa.from('evolutto_banners').delete().eq('id', id);
      if (error) alert('Erro: ' + error.message); else carregar();
    }

    async function carregar() {
      const session = await requireAuth(); if (!session) return;
      const { data, error } = await supa.from('evolutto_banners').select('*').order('created_at', { ascending: false });
      if (error) { grid.innerHTML = `<p class="text-red-500 text-sm">Erro: ${esc(error.message)}</p>`; return; }
      const list = data || [];
      if (!list.length) { grid.innerHTML = '<p class="text-gray-400 text-sm">Nenhum banner ainda. Clique em “Novo banner”.</p>'; return; }
      grid.innerHTML = list.map((b) => `
        <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
          <div class="aspect-[16/6] bg-evolutto-gradient relative bg-cover bg-center" ${b.imagem_url ? `style="background-image:url('${esc(b.imagem_url)}')"` : ''}>
            <button class="t-ativo absolute top-3 right-3 text-[0.6rem] font-bold uppercase tracking-widest px-2.5 py-1 rounded-full ${b.ativo ? 'bg-green-100 text-green-700' : 'bg-gray-200 text-gray-500'}" data-id="${b.id}" data-ativo="${b.ativo}">${b.ativo ? 'Ativo' : 'Inativo'}</button>
          </div>
          <div class="p-5">
            <h3 class="font-bold text-gray-900">${esc(b.titulo)}</h3>
            <p class="text-xs text-gray-500 mt-1">${esc(b.posicao || '—')}${b.link ? ' · ' + esc(b.link) : ''}</p>
            <div class="flex items-center gap-2 mt-4">
              <button class="b-editar flex-1 text-sm font-semibold text-gray-700 border border-gray-300 rounded-full py-2 hover:bg-gray-50 hover:border-evolutto-blue/40 hover:text-evolutto-blue transition-colors" data-id="${b.id}">Editar</button>
              <button class="b-excluir w-10 h-10 grid place-items-center rounded-full border border-gray-300 text-gray-500 hover:text-evolutto-red hover:border-evolutto-red/40 transition-colors" data-id="${b.id}" aria-label="Excluir"><i class="w-4 h-4" data-lucide="trash-2"></i></button>
            </div>
          </div>
        </div>`).join('');
      createIcons({ icons });
      grid.querySelectorAll<HTMLElement>('.t-ativo').forEach((x) => x.addEventListener('click', () => toggleAtivo(x.dataset.id!, x.dataset.ativo === 'true')));
      grid.querySelectorAll<HTMLElement>('.b-editar').forEach((x) => x.addEventListener('click', () => abrirEdicao(list.find((y) => y.id === x.dataset.id))));
      grid.querySelectorAll<HTMLElement>('.b-excluir').forEach((x) => x.addEventListener('click', () => excluir(x.dataset.id!)));
    }
    carregar();
  </script>
</CmsLayout>
